rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to all collections
    match /{document=**} {
      allow read: if true;
    }

    // Allow write access (create, update, delete) only to authenticated users for all collections
    match /{document=**} {
      allow write: if request.auth != null;
    }
  }
}
