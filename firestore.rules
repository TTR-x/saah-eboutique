rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Products, slides, and testimonials can be read by anyone.
    // Only authenticated users (admin) can create, update, or delete them.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /slides/{slideId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if true; // Anyone can submit a testimonial
      allow update, delete: if request.auth != null; // Only admin can edit/delete
    }

    // Reviews can be created by anyone, but only the admin can modify them.
    match /products/{productId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Contact messages can be created by anyone, but only read by the admin.
    match /contact-messages/{messageId} {
      allow read, delete: if request.auth != null;
      allow create: if true;
    }
  }
}
