rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public collections: anyone can read, only authenticated can write/edit
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /slides/{slideId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Testimonials: everyone can read/create, only authenticated can edit/delete
    match /testimonials/{testimonialId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Reviews: everyone can read/create, only authenticated can edit/delete
    match /products/{productId}/reviews/{reviewId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Contact messages: anyone can create, only authenticated can read/manage
    match /contact-messages/{messageId} {
        allow create: if true;
        allow read, update, delete: if request.auth != null;
    }
  }
}
