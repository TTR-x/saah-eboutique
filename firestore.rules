
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if the user is the administrator
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "sabbataka02@gmail.com";
    }

    // Products can be read by anyone, but only modified by an admin.
    // Reviews can be read by anyone, and created by anyone, but only modified by an admin.
    match /products/{productId} {
      allow read: true;
      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: true;
        allow create: if request.resource.data.rating > 0 && request.resource.data.userName != "" && request.resource.data.comment != "";
        allow update, delete: if isAdmin();
      }
    }

    // Slides can be read by anyone, but only modified by an admin.
    match /slides/{slideId} {
      allow read: true;
      allow write: if isAdmin();
    }
    
    // Testimonials can be read by anyone, and created by anyone, but only modified by an admin.
    match /testimonials/{testimonialId} {
        allow read: true;
        allow create: if request.resource.data.rating > 0 && request.resource.data.name != "" && request.resource.data.comment != "";
        allow update, delete: if isAdmin();
    }
    
    // Contact messages can be created by anyone, but only read/modified by an admin.
    match /contact-messages/{messageId} {
        allow create: true;
        allow read, update, delete: if isAdmin();
    }

    // Import orders can be created by anyone, but only read/modified by an admin.
    match /import-orders/{orderId} {
        allow create: true;
        allow read, update, delete: if isAdmin();
    }
  }
}
