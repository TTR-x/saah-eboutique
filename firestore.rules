
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Autoriser la lecture et l'écriture pour n'importe quel utilisateur connecté.
    // C'est une règle de base pour démarrer. Nous pourrons la rendre plus stricte plus tard.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
