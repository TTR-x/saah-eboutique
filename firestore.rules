rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "sabbataka02@gmail.com";
    }

    // Products can be read by anyone, but only modified by an admin.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Anyone can create a review, but only authenticated users can update/delete their own.
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if request.auth != null;
      }
    }

    // Slides can be read by anyone, but only modified by an admin.
    match /slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials can be read by anyone. Anyone can create, admin can delete.
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if true;
      allow write: if isAdmin();
    }
    
    // Contact messages can be created by anyone. Read/write restricted to admin.
    match /contact-messages/{messageId} {
      allow read, write: if isAdmin();
      allow create: if true;
    }
    
    // Import orders can be created by anyone. Read/write restricted to admin.
    match /import-orders/{orderId} {
      allow read, write: if isAdmin();
      allow create: if true;
    }
  }
}
