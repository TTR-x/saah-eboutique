
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default rule: block all access unless specified otherwise
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public read on products, slides, and testimonials
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null; // Create, Update, Delete for authenticated users
    }

    match /slides/{slideId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if true; // Anyone can submit a testimonial
      allow update, delete: if request.auth != null; // Only admin can manage them
    }

    // Reviews can be read by anyone. Anyone can create one.
    // Only authenticated users can update/delete (future proofing for admin).
    match /products/{productId}/reviews/{reviewId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if request.auth != null;
    }

    // Contact messages can only be created by anyone.
    // Only authenticated users (admin) can read or delete them.
    match /contact-messages/{messageId} {
        allow read, delete: if request.auth != null;
        allow create: if true;
    }
  }
}
