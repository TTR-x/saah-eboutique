
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Autorise la lecture et l'écriture pour n'importe quel utilisateur authentifié.
    // C'est une bonne règle pour commencer le développement.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
