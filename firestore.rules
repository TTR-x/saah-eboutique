rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Règle par défaut : lecture publique, écriture authentifiée
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Les visiteurs peuvent envoyer des messages de contact
    match /contact-messages/{messageId} {
      allow create: if true;
    }

    // Les visiteurs peuvent ajouter des témoignages
    match /testimonials/{testimonialId} {
      allow create: if true;
    }

    // Les visiteurs peuvent ajouter des avis sur les produits
    match /products/{productId}/reviews/{reviewId} {
      allow create: if true;
    }
  }
}
