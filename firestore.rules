rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is the admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "sabbataka02@gmail.com";
    }

    // Products can be read by anyone, but only written by admin
    match /products/{productId} {
      allow read;
      allow write: if isAdmin();

      // Anyone can submit a review
      match /reviews/{reviewId} {
        allow read, create: if true;
        allow update, delete: if isAdmin();
      }
    }

    // Slides can be read by anyone, but only written by admin
    match /slides/{slideId} {
      allow read;
      allow write: if isAdmin();
    }
    
    // Testimonials can be read by anyone, but only written by admin (or anyone can add one)
    match /testimonials/{testimonialId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Contact messages can be created by anyone
    match /contact-messages/{messageId} {
      allow create;
      allow read, update, delete: if isAdmin();
    }

    // Import orders can be created by anyone
    match /import-orders/{orderId} {
      allow create;
      allow read, update, delete: if isAdmin();
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
