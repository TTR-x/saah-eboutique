
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'sabbataka02@gmail.com';
    }

    // Default deny all reads/writes unless specified below
    match /{document=**} {
      allow read, write: if false;
    }

    // Products: Public can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews: Public can read, anyone can create, only admin can delete/update
    match /products/{productId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Slides: Public can read, only admin can write
    match /slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Testimonials: Public can read, anyone can create, only admin can delete/update
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Contact Messages: Anyone can create, only admin can read/update/delete
    match /contact-messages/{messageId} {
      allow read, update, delete: if isAdmin();
      allow create: if true;
    }

    // Import Orders: Anyone can create, only admin can read/update/delete
    match /import-orders/{orderId} {
      allow read, update, delete: if isAdmin();
      allow create: if true;
    }
  }
}
