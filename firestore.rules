
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // N'importe qui peut lire les données publiques (produits, slides, etc.)
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null; // Seul l'admin connecté peut écrire
      
      // Les avis peuvent être lus par tous, et créés par tous
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if true; // Tout le monde peut ajouter un avis
        allow update, delete: if request.auth != null; // Seul l'admin peut modifier/supprimer
      }
    }

    match /slides/{slideId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if true; // Tout le monde peut ajouter un témoignage
      allow update, delete: if request.auth != null;
    }

    match /contact-messages/{messageId} {
      allow create: if true; // Tout le monde peut envoyer un message
      allow read, update, delete: if request.auth != null; // Seul l'admin peut gérer les messages
    }
  }
}
