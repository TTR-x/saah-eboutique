[debug] [2025-07-27T04:15:31.776Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // N'importe qui peut lire les données publiques (produits, slides, etc.)\n    match /products/{productId} {\n      allow read: if true;\n      allow write: if request.auth != null; // Seul l'admin connecté peut écrire\n      \n      // Les avis peuvent être lus par tous, et créés par tous\n      match /reviews/{reviewId} {\n        allow read: if true;\n        allow create: if true; // Tout le monde peut ajouter un avis\n        allow update, delete: if request.auth != null; // Seul l'admin peut modifier/supprimer\n      }\n    }\n\n    match /slides/{slideId} {\n      allow read: if true;\n      allow write: if request.auth != null;\n    }\n\n    match /testimonials/{testimonialId} {\n      allow read: if true;\n      allow create: if true; // Tout le monde peut ajouter un témoignage\n      allow update, delete: if request.auth != null;\n    }\n\n    match /contact-messages/{messageId} {\n      allow create: if true; // Tout le monde peut envoyer un message\n      allow read, update, delete: if request.auth != null; // Seul l'admin peut gérer les messages\n    }\n  }\n}\n"}]}}
