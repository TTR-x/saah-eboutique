[debug] [2025-07-27T06:58:34.791Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Default: Deny all reads and writes\n    match /{document=**} {\n      allow read: if true;\n      allow write: if request.auth != null;\n    }\n\n    // Products: Public read, only authenticated write\n    match /products/{productId} {\n      allow read: if true;\n      allow create, update, delete: if request.auth != null;\n    }\n\n    // Product reviews: Public read, any user can create\n    match /products/{productId}/reviews/{reviewId} {\n      allow read: if true;\n      allow create: if true; // Or `if request.auth != null` if only logged in users can review\n    }\n    \n    // Slides: Public read, only authenticated write\n    match /slides/{slideId} {\n      allow read: if true;\n      allow create, update, delete: if request.auth != null;\n    }\n\n    // Testimonials: Public read, any user can create\n    match /testimonials/{testimonialId} {\n      allow read: if true;\n      allow create: if true;\n    }\n\n    // Contact Messages: Public read for admin, any user can create\n    match /contact-messages/{messageId} {\n      allow read, update, delete: if request.auth != null; // Only admin should access\n      allow create: if true;\n    }\n  }\n}\n"}]}}
