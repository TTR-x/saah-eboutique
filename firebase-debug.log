[debug] [2025-07-28T09:00:53.433Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to check if the user is the administrator\n    function isAdmin() {\n      return request.auth != null && request.auth.token.email == \"sabbataka02@gmail.com\";\n    }\n\n    // Products can be read by anyone, but only modified by an admin.\n    // Reviews can be read by anyone, and created by anyone, but only modified by an admin.\n    match /products/{productId} {\n      allow read: true;\n      allow write: if isAdmin();\n\n      match /reviews/{reviewId} {\n        allow read: true;\n        allow create: if request.resource.data.rating > 0 && request.resource.data.userName != \"\" && request.resource.data.comment != \"\";\n        allow update, delete: if isAdmin();\n      }\n    }\n\n    // Slides can be read by anyone, but only modified by an admin.\n    match /slides/{slideId} {\n      allow read: true;\n      allow write: if isAdmin();\n    }\n    \n    // Testimonials can be read by anyone, and created by anyone, but only modified by an admin.\n    match /testimonials/{testimonialId} {\n        allow read: true;\n        allow create: if request.resource.data.rating > 0 && request.resource.data.name != \"\" && request.resource.data.comment != \"\";\n        allow update, delete: if isAdmin();\n    }\n    \n    // Contact messages can be created by anyone, but only read/modified by an admin.\n    match /contact-messages/{messageId} {\n        allow create: true;\n        allow read, update, delete: if isAdmin();\n    }\n\n    // Import orders can be created by anyone, but only read/modified by an admin.\n    match /import-orders/{orderId} {\n        allow create: true;\n        allow read, update, delete: if isAdmin();\n    }\n  }\n}\n"}]}}
