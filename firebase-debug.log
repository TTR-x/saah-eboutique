[debug] [2025-07-27T04:44:54.278Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Default: anyone can read, only authenticated users can write.\n    match /{document=**} {\n      allow read: if true;\n      allow write: if request.auth != null;\n    }\n\n    // Contact messages: anyone can create.\n    match /contact-messages/{messageId} {\n      allow create: if true;\n    }\n\n    // Testimonials: anyone can create.\n    match /testimonials/{testimonialId} {\n      allow create: if true;\n    }\n    \n    // Slides: only authenticated users can manage.\n    match /slides/{slideId} {\n        allow read: if true;\n        allow create, update, delete: if request.auth != null;\n    }\n\n    // Products: Temporarily allow public write for testing.\n    // ⚠️ This is for debugging only.\n    match /products/{productId} {\n      allow read: if true;\n      allow write: if true; // Temporary rule for testing\n    }\n\n    // Product reviews: anyone can create.\n    match /products/{productId}/reviews/{reviewId} {\n      allow create: if true;\n      // Authenticated users can manage their own reviews (optional future enhancement)\n      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;\n    }\n  }\n}\n"}]}}
