[debug] [2025-08-10T16:33:14.136Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check if the user is the admin\n    function isAdmin() {\n      return request.auth != null && request.auth.token.email == \"sabbataka02@gmail.com\";\n    }\n\n    // Products can be read by anyone, but only written by admin\n    match /products/{productId} {\n      allow read;\n      allow write: if isAdmin();\n\n      // Anyone can submit a review\n      match /reviews/{reviewId} {\n        allow read, create: if true;\n        allow update, delete: if isAdmin();\n      }\n    }\n\n    // Slides can be read by anyone, but only written by admin\n    match /slides/{slideId} {\n      allow read;\n      allow write: if isAdmin();\n    }\n    \n    // Testimonials can be read by anyone, but only written by admin (or anyone can add one)\n    match /testimonials/{testimonialId} {\n      allow read, create: if true;\n      allow update, delete: if isAdmin();\n    }\n\n    // Contact messages can be created by anyone\n    match /contact-messages/{messageId} {\n      allow create;\n      allow read, update, delete: if isAdmin();\n    }\n\n    // Import orders can be created by anyone\n    match /import-orders/{orderId} {\n      allow create;\n      allow read, update, delete: if isAdmin();\n    }\n    \n    // Default deny all other collections\n    match /{document=**} {\n      allow read, write: if isAdmin();\n    }\n  }\n}\n"}]}}
