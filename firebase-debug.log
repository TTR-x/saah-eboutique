[debug] [2025-07-27T04:38:22.990Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Règle générale : tout le monde peut lire, seuls les utilisateurs authentifiés peuvent écrire\n    match /{document=**} {\n      allow read: if true;\n      allow write: if request.auth != null;\n    }\n\n    // Messages de contact : tout le monde peut créer\n    match /contact-messages/{messageId} {\n      allow create: if true;\n    }\n\n    // Témoignages : tout le monde peut créer\n    match /testimonials/{testimonialId} {\n      allow create: if true;\n    }\n\n    // Produits : seuls les utilisateurs authentifiés peuvent créer/modifier\n    match /products/{productId} {\n      allow read: if true;\n      allow create, update, delete: if request.auth != null;\n    }\n\n    // Avis sur les produits : tout le monde peut créer\n    match /products/{productId}/reviews/{reviewId} {\n      allow create: if true;\n    }\n  }\n}\n"}]}}
