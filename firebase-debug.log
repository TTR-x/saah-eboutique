[debug] [2025-07-27T06:31:54.878Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Par défaut, refuser l'accès\n    match /{document=**} {\n      allow read, write: if false;\n    }\n\n    // Autoriser la lecture publique des collections nécessaires au site\n    match /products/{productId} {\n      allow read: if true;\n    }\n    match /products/{productId}/reviews/{reviewId} {\n      allow read: if true;\n    }\n    match /slides/{slideId} {\n      allow read: if true;\n    }\n     match /testimonials/{testimonialId} {\n      allow read: if true;\n    }\n\n    // Autoriser la création de messages, avis et témoignages par tout le monde\n    match /contact-messages/{messageId} {\n      allow create: if true;\n    }\n     match /testimonials/{testimonialId} {\n      allow create: if true;\n    }\n    match /products/{productId}/reviews/{reviewId} {\n      allow create: if true;\n    }\n    \n    // Autoriser les administrateurs (authentifiés) à tout faire sur les produits, slides et messages\n    match /products/{productId} {\n      allow write: if request.auth != null;\n    }\n    match /slides/{slideId} {\n      allow write: if request.auth != null;\n    }\n    match /contact-messages/{messageId} {\n      allow read, update, delete: if request.auth != null;\n    }\n  }\n}\n"}]}}
