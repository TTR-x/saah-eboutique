[debug] [2026-03-12T14:31:09.159Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Fonction pour vérifier si l'utilisateur est l'admin officiel\n    function isAdmin() {\n      return request.auth != null && request.auth.token.email == \"saahbusiness2026@gmail.com\";\n    }\n\n    // --- Profils Utilisateurs ---\n    match /users/{userId} {\n      allow read, write: if request.auth != null && request.auth.uid == userId;\n      allow read: if isAdmin();\n    }\n\n    // --- Produits ---\n    match /products/{productId} {\n      allow read: if true; // Tout le monde peut voir les plans\n      allow write: if isAdmin(); // Seul l'admin peut modifier\n    }\n\n    // --- Commandes ---\n    match /orders/{orderId} {\n      allow create: if request.auth != null;\n      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());\n      allow update, delete: if isAdmin();\n    }\n\n    // --- Slides (Carousel) ---\n    match /slides/{slideId} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    // --- Témoignages ---\n    match /testimonials/{testimonialId} {\n      allow read: if true;\n      allow create: if true; // N'importe qui peut laisser un avis\n      allow update, delete: if isAdmin();\n    }\n\n    // --- Messages de Contact ---\n    match /contact-messages/{messageId} {\n      allow create: if true; // Public pour le formulaire\n      allow read, update, delete: if isAdmin(); // Seul l'admin peut gérer\n    }\n\n    // --- Demandes d'Importation ---\n    match /import-orders/{orderId} {\n      allow create: if true; // Public pour le formulaire\n      allow read, update, delete: if isAdmin(); // Seul l'admin peut gérer\n    }\n\n    // --- Règle par défaut ---\n    match /{document=**} {\n      allow read, write: if isAdmin();\n    }\n  }\n}\n"}]}}
