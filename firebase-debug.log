[debug] [2026-03-10T12:06:16.081Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Fonctions utilitaires\n    function isAdmin() {\n      return request.auth != null && request.auth.token.email == \"saahbusiness2026@gmail.com\";\n    }\n\n    // Accès public en lecture pour le contenu du site\n    match /products/{productId} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    match /slides/{slideId} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    match /testimonials/{testimonialId} {\n      allow read: if true;\n      allow create: if true; // N'importe qui peut laisser un avis\n      allow update, delete: if isAdmin();\n    }\n\n    // Autoriser tout le monde à envoyer des messages, mais seul l'admin peut les lire\n    match /contact-messages/{messageId} {\n      allow create: if true;\n      allow read, update, delete: if request.auth != null;\n    }\n\n    // Autoriser tout le monde à passer une commande d'importation\n    match /import-orders/{orderId} {\n      allow create: if true;\n      allow read, update, delete: if request.auth != null;\n    }\n\n    // Règle par défaut : refuser tout le reste\n    match /{document=**} {\n      allow read, write: if isAdmin();\n    }\n  }\n}"}]}}
