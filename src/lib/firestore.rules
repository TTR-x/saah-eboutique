
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction pour vérifier si l'utilisateur est l'admin officiel
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "saahbusiness2026@gmail.com";
    }

    // --- Profils Utilisateurs ---
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // --- Produits ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Slides ---
    match /slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Témoignages ---
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // --- Messages de Contact ---
    match /contact-messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // --- Demandes d'Importation ---
    match /import-orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // --- Règle par défaut ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
