
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Profil utilisateur pour les clients et l'administrateur.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Article en vente dans le catalogue.",
      "type": "object",
      "properties": {
        "sku": { "type": "string", "description": "Référence unique du produit (ex: SAAH-XXXX)." },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "imagePublicIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "allowDelivery": { "type": "boolean" },
        "deliveryFees": { "type": "number" },
        "isTontine": { "type": "boolean" },
        "tontineDuration": { "type": "string" },
        "tontineDailyRate": { "type": "number", "description": "Somme minimum par jour pour la tontine." },
        "allowInstallments": { "type": "boolean" },
        "installmentPrice": { "type": "number" },
        "installmentMonths": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviews": { "type": "number" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Commande ou intention d'achat d'un client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "productId": { "type": "string" },
        "productSku": { "type": "string" },
        "productName": { "type": "string" },
        "productImage": { "type": "string" },
        "amount": { "type": "number" },
        "totalPrice": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "paymentMode": { "type": "string", "enum": ["cash", "installments", "tontine"] },
        "status": { "type": "string", "enum": ["pending", "validated", "completed", "cancelled", "payment_pending", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "paymentHistory": { "type": "array", "items": { "type": "object" } },
        "isDelivery": { "type": "boolean" },
        "address": { "type": "string" },
        "transferId": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "Copie d'un paiement validé pour l'historique.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "productName": { "type": "string" },
        "productImage": { "type": "string" },
        "paymentMode": { "type": "string" },
        "transferId": { "type": "string" },
        "remainingAmountAfter": { "type": "number" }
      }
    },
    "GiftRequest": {
      "title": "GiftRequest",
      "description": "Demande de cadeau effectuée par un client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "chosenGift": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Données privées de l'utilisateur."
    },
    "/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Catalogue des articles."
    },
    "/orders/{orderId}": {
      "schema": "#/backend/entities/Order",
      "description": "Historique des commandes et intentions d'achat."
    },
    "/payments/{paymentId}": {
      "schema": "#/backend/entities/Payment",
      "description": "Copies des paiements validés (Historique immuable)."
    },
    "/gift-requests/{requestId}": {
      "schema": "#/backend/entities/GiftRequest",
      "description": "Demandes de cadeaux en attente."
    }
  }
}
