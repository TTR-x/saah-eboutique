
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Profil utilisateur pour les clients et l'administrateur.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Article en vente dans le catalogue.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "isTontine": { "type": "boolean" },
        "allowInstallments": { "type": "boolean" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Commande ou intention d'achat d'un client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "productImage": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMode": { "type": "string", "enum": ["cash", "installments"] },
        "status": { "type": "string", "enum": ["pending", "validated", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "isDelivery": { "type": "boolean" },
        "address": { "type": "string" }
      }
    },
    "GiftRequest": {
      "title": "GiftRequest",
      "description": "Demande de cadeau effectuée par un client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "chosenGift": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Gift": {
      "title": "Gift",
      "description": "Cadeau envoyé par l'administrateur à un client.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Données privées de l'utilisateur."
    },
    "/users/{userId}/gifts/{giftId}": {
      "schema": "#/backend/entities/Gift",
      "description": "Cadeaux reçus par l'utilisateur."
    },
    "/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Catalogue des articles."
    },
    "/orders/{orderId}": {
      "schema": "#/backend/entities/Order",
      "description": "Historique des commandes et intentions d'achat."
    },
    "/gift-requests/{requestId}": {
      "schema": "#/backend/entities/GiftRequest",
      "description": "Demandes de cadeaux en attente."
    },
    "/contact-messages/{messageId}": {
      "schema": "object",
      "description": "Messages envoyés via le support."
    },
    "/import-orders/{orderId}": {
      "schema": "object",
      "description": "Demandes d'importation."
    }
  }
}
